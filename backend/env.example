# API Settings
API_PREFIX=/api/v1
PROJECT_NAME="CVSU-Carmona Alumni Document Verification System"
PROJECT_VERSION="1.0.0"

# CORS settings
# Comma-separated list of allowed origins
CORS_ORIGINS=https://alumni-frontend-zzr2.onrender.com,http://localhost:3000,http://localhost:5173

# Frontend URL (for redirects and email links)
FRONTEND_URL=https://alumni-frontend-zzr2.onrender.com

# MongoDB Settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=cvsu_alumni

# JWT Authentication settings 
SECRET_KEY=your-secure-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=7       # 7 days

# Email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@cvsu.edu.ph
EMAILS_FROM_NAME="CVSU Alumni System"

# Admin settings
ADMIN_DEFAULT_PASSWORD=ChangeThisToSecurePassword!123
ADMIN_BYPASS_EMAIL=admin@cvsu.edu.ph 