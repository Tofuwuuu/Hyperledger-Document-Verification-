# MongoDB Settings
MONGODB_URL=mongodb://localhost:27017/cvsu_alumni
MONGODB_DB=cvsu_alumni

# JWT Authentication Settings
SECRET_KEY=please_change_this_to_a_secure_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin Authentication
ADMIN_BYPASS_EMAIL=admin.bypass@example.com
ADMIN_DEFAULT_PASSWORD=ChangeThisPassword123

# API Settings
API_V1_STR=/api/v1

# Frontend URL for redirects and CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Blockchain Settings
USE_REAL_BLOCKCHAIN=false
NETWORK_CONFIG_PATH=backend/app/blockchain/network-config.yaml
ORG_NAME=Org1
ORG_USER=Admin
CHANNEL_NAME=mychannel
CHAINCODE_NAME=document-verification
CONTRACT_NAME=

# Email Settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_password
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME=CVSU Alumni System

# Feature Flags
WEBSOCKETS_ENABLED=false
NOTIFICATIONS_ENABLED=true
NOTIFICATION_CLEANUP_DAYS=30
BLOCKCHAIN_ENABLED=false

# WebSocket Settings
WS_CONNECTION_LIFETIME=3600
WS_PING_INTERVAL=30

# Jitsi Meeting Settings
JITSI_APP_ID=alumni_app_id
JITSI_APP_SECRET=your_jitsi_secret_key
JITSI_JWT_ISSUER=alumni_app
JITSI_JWT_AUDIENCE=jitsi
JITSI_JWT_HOURS=24

# Logging
LOG_LEVEL=INFO
