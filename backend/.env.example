MONGODB_URL=mongodb://localhost:27017/cvsu_alumni
MONGODB_URI=

# Used later for JWT/auth; present now for compatibility with your deployment guide.
SECRET_KEY=change_me

# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Defaults for local dev
ENV=development
ENABLE_CSRF=false

# Real Hyperledger Fabric mode. Use http://localhost:3001 when running
# backend locally and fabric-gateway through Docker.
USE_REAL_BLOCKCHAIN=true
FABRIC_GATEWAY_URL=http://localhost:3001
CHANNEL_NAME=alumni-channel
CHAINCODE_NAME=final-smart-contract
